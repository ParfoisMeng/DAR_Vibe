{
  "name": "dar-vibe-phase0",
  "version": "0.0.1",
  "description": "问道无界 Phase 0 原型",
  "scripts": {
    "dev": "npx esbuild src/main.ts --bundle --outfile=dist/bundle.js --watch --sourcemap",
    "build": "npx esbuild src/main.ts --bundle --outfile=dist/bundle.js --minify",
    "serve": "npx http-server . -p 3000 -o",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:all": "npm run test && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "esbuild": "^0.25.0",
    "jsdom": "^29.1.0",
    "playwright": "^1.59.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
